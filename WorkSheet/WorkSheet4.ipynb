   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.feature_selection import mutual_info_classif\n",
    "\n",
    "# 1. Load the dataset\n",
    "df = pd.read_csv('irisData.csv')\n",
    "X = df.iloc[:, :-1]\n",
    "y = df.iloc[:, -1]\n",
    "\n",
    "# 2. Calculate Information Gain (Mutual Information) for each feature\n",
    "# mutual_info_classif uses the principle of Information Gain\n",
    "importances = mutual_info_classif(X, y, random_state=42)\n",
    "\n",
    "# Create a summary table\n",
    "feature_gain = pd.Series(importances, index=X.columns)\n",
    "feature_gain = feature_gain.sort_values(ascending=False)\n",
    "\n",
    "print(\"Information Gain for each feature:\")\n",
    "print(feature_gain)\n",
    "print(\"-\" * 30)\n",
    "\n",
    "# 3. Select the best 2 features\n",
    "best_2_features = feature_gain.head(2).index.tolist()\n",
    "print(f\"The best 2 features based on Information Gain are: {best_2_features}\")\n",
    "\n",
    "# 4. Optional: Create a new dataframe with only the best features\n",
    "X_selected = X[best_2_features]\n",
    "print(\"\\nFirst 5 rows of selected features:\")\n",
    "print(X_selected.head())"
