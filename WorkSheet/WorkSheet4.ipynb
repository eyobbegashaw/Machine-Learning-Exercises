  {
   "cell_type": "markdown",
   "id": "82fcc934",
   "metadata": {},
   "source": [
    "A.Calculate the mean absolute error (MAE) <br>\n",
    "B.Calculate the root mean squared error (RMSE) <br>\n",
    "C.Calculate the squares error (MSE) <br>\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e78d157f",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "# Data from the table\n",
    "actual = np.array([1, 0, 1, 0, 0, 0, 1, 1, 1, 0, 1, 0, 0, 0, 1, 1])\n",
    "predicted = np.array([1, 0, 1.1, 0.2, 0.2, 0, 1.1, 1.2, 0.9, 0.1, 1, 0, 0, 1, 1, 0.8])\n",
    "\n",
    "# Calculations\n",
    "mae = np.mean(np.abs(actual - predicted))\n",
    "mse = np.mean((actual - predicted)**2)\n",
    "rmse = np.sqrt(mse)\n",
    "\n",
    "print(f\"Mean Absolute Error (MAE): {mae:.4f}\")\n",
    "print(f\"Mean Squared Error (MSE): {mse:.4f}\")\n",
    "print(f\"Root Mean Squared Error (RMSE): {rmse:.4f}\")"
   ]
  },
