   "id": "b7dae03b",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from sklearn.model_selection import KFold\n",
    "\n",
    " \n",
    "df = pd.read_csv('irisData.csv')\n",
    "\n",
    " \n",
    "kf = KFold(n_splits=10, shuffle=True, random_state=42)\n",
    "\n",
    "print(\"Applying 10-fold cross-validation on irisData.csv...\")\n",
    "print(f\"Total samples: {len(df)}\")\n",
    "print(\"-\" * 30)\n",
    "\n",
    "fold = 1\n",
    "for train_index, test_index in kf.split(df):\n",
    "    print(f\"Fold {fold}:\")\n",
    "    print(f\"  Training set size: {len(train_index)}\")\n",
    "    print(f\"  Testing (Validation) set size: {len(test_index)}\")\n",
    "    fold += 1\n",
    "\n",
    "print(\"-\" * 30)\n",
    "print(\"10-fold partitioning complete.\")"
   ]
